{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "phases": {
    "setup": {
      "nixPkgs": ["jdk11", "maven"]
    },
    "build": {
      "cmds": ["cd starrating-backend && mvn clean install -DskipTests"]
    }
  },
  "deploy": {
    "startCommand": "java -jar starrating-backend/target/*.jar --server.port=$PORT"
  }
}
